[
  {
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight",
      // Open a new terminal in the center pane (there is no action to move an
      // existing dock terminal to center — drag its tab for that)
      "ctrl-alt-`": "workspace::NewCenterTerminal",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-shift-h": "pane::ActivatePreviousItem",
      "ctrl-shift-l": "pane::ActivateNextItem",
      // Move the current tab into the neighboring pane (creates the split if
      // needed; overrides vim's default ctrl-w hjkl pane navigation, which
      // ctrl-hjkl already covers)
      "ctrl-w h": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "left" },
      ],
      "ctrl-w j": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "down" },
      ],
      "ctrl-w k": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "up" },
      ],
      "ctrl-w l": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "right" },
      ],
      // Swap the focused pane with its neighbor (overrides vim's default
      // ctrl-w shift-hjkl "move pane to far edge")
      "ctrl-w shift-h": "workspace::SwapPaneLeft",
      "ctrl-w shift-j": "workspace::SwapPaneDown",
      "ctrl-w shift-k": "workspace::SwapPaneUp",
      "ctrl-w shift-l": "workspace::SwapPaneRight",
    },
  },
  {
    "context": "NotebookEditor && notebook_mode == command",
    "bindings": {
      "h": "menu::SelectPrevious",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "menu::SelectNext",
    },
  },
  {
    "context": "NotebookEditor > Editor && VimControl && vim_mode == normal",
    "bindings": {
      "j": "notebook::NotebookMoveDown",
      "k": "notebook::NotebookMoveUp",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": ["terminal::SendKeystroke", "ctrl-j"],
      "ctrl-k": ["terminal::SendKeystroke", "ctrl-k"],
      "ctrl-l": "workspace::ActivatePaneRight",
      // Pane navigation incl. up/down, since ctrl-j/k are sent to the shell
      "ctrl-shift-h": "pane::ActivatePreviousItem",
      "ctrl-shift-l": "pane::ActivateNextItem",
    },
  },
  {
    "context": "Terminal",
    "unbind": {
      "alt-enter": "search::SelectAllMatches",
    },
  },
  {
    "context": "menu",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrevious",
    },
  },
  {
    "context": "Workspace && os == macos",
    "bindings": {
      "cmd-shift-g": [
        "task::Spawn",
        {
          "task_name": "LazyGit",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    // Override Zed's default cmd-shift-y (git::UnstageFile) in editors —
    // the Editor context is deeper than Workspace, so a Workspace-level
    // binding would lose to that default
    "context": "Editor",
    "bindings": {
      "cmd-shift-y": [
        "task::Spawn",
        {
          "task_name": "Yazi (Current File)",
          "reveal_target": "center",
        },
      ],
      // Likewise override the default cmd-shift-o (outline::Toggle)
      "cmd-shift-o": [
        "task::Spawn",
        {
          "task_name": "Television Project Finder",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "Workspace && os == windows",
    "bindings": {
      "secondary-shift-g": [
        "task::Spawn",
        {
          "task_name": "LazyGit",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "Workspace && os == linux",
    "bindings": {
      "secondary-shift-g": [
        "task::Spawn",
        {
          "task_name": "LazyGit",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space g": [
        "task::Spawn",
        {
          "task_name": "LazyGit",
          "reveal_target": "center",
        },
      ],
      "space y": [
        "task::Spawn",
        {
          "task_name": "Yazi",
          "reveal_target": "center",
        },
      ],
      "space f f": "file_finder::Toggle",
      "space f s": [
        "task::Spawn",
        {
          "task_name": "Television File Finder",
          "reveal_target": "center",
        },
      ],
      "space f w": [
        "task::Spawn",
        {
          "task_name": "Television Text Search",
          "reveal_target": "center",
        },
      ],
      "space f p": [
        "task::Spawn",
        {
          "task_name": "Television Project Finder",
          "reveal_target": "center",
        },
      ],
      "space c": [
        "task::Spawn",
        {
          "task_name": "Claude Code",
          "reveal_target": "center",
        },
      ],
      "g w": ["workspace::SendKeystrokes", "v i w g w"],
    },
  },
  {
    "context": "vim_mode == visual && !menu",
    "bindings": {
      "g w": [
        "task::Spawn",
        {
          "task_name": "Television Text Search (Word)",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
    },
  },
  {
    "bindings": {
      "cmd-shift-c": [
        "task::Spawn",
        {
          "task_name": "Claude Code",
          "reveal_target": "center",
        },
      ],
      "cmd-shift-y": [
        "task::Spawn",
        {
          "task_name": "Yazi (Current File)",
          "reveal_target": "center",
        },
      ],
      "cmd-shift-o": [
        "task::Spawn",
        {
          "task_name": "Television Project Finder",
          "reveal_target": "center",
        },
      ],
    },
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-cmd-b": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Editor && mode == full",
    "unbind": {
      "cmd-e": "buffer_search::UseSelectionForFind"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "cmd-b": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-b": "multi_workspace::ToggleWorkspaceSidebar"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "alt-cmd-j": "multi_workspace::ToggleWorkspaceSidebar"
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "cmd-shift-g": "search::SelectPreviousMatch"
    }
  }
]
