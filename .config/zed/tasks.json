[
  {
    "label": "LazyGit",
    "command": "lazygit",
    "shell": "system",
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Yazi",
    "command": "f",
    "shell": {
      "program": "fish"
    },
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Television File Finder",
    "command": "zed \"$(tv files)\"",
    "shell": "system",
    "env": {
      "BAT_THEME": "OneHalfLight"
    },
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Television Text Search",
    "command": "zed \"$(tv text)\"",
    "env": {
      "BAT_THEME": "OneHalfLight"
    },
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Television Text Search (Word)",
    "command": "zed \"$(tv text --input \"$ZED_SELECTED_TEXT\")\"",
    "env": {
      "BAT_THEME": "OneHalfLight"
    },
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  }
]
