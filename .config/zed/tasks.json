[
  {
    "label": "LazyGit",
    "command": "lazygit",
    "shell": "system",
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Television File Finder",
    "command": "$env:Path = [Environment]::GetEnvironmentVariable('Path', 'Machine') + ';' + [Environment]::GetEnvironmentVariable('Path', 'User'); zed \"$(tv files)\"",
    "shell": {
      "with_arguments": {
        "program": "pwsh",
        "args": ["-NoLogo"]
      }
    },
    "env": {
      "BAT_THEME": "OneHalfLight"
    },
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  },
  {
    "label": "Television Text Search",
    "command": "zed \"$(tv text)\"",
    "env": {
      "BAT_THEME": "OneHalfLight"
    },
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true
  }
]
