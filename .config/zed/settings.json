// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette
{
  "buffer_font_weight": 400.0,
  "buffer_font_family": "UDEV Gothic NFLG",
  "cli_default_open_behavior": "existing_window",
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Latte",
    "dark": "Zed (Default)",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "agent_servers": {
    "cursor": {
      "default_config_options": {
        "model": "composer-2.5[fast=true]",
      },
      "favorite_config_option_values": {
        "model": ["composer-2.5[fast=true]"],
      },
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "default_config_options": {
        "model": "opus[1m]",
        "mode": "auto",
      },
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "redact_private_values": false,
  "indent_guides": {
    "coloring": "fixed",
  },
  "tabs": {
    "file_icons": true,
    "git_status": false,
  },
  "agent": {
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow",
        },
      },
    },
    "favorite_models": [
      {
        "provider": "openai-subscribed",
        "model": "gpt-5.5",
        "enable_thinking": true,
        "effort": "medium",
      },
      {
        "provider": "anthropic",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false,
      },
    ],
    "dock": "right",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "model_parameters": [],
  },
  "language_models": {
    "anthropic": {
      "api_url": "https://lm-litellm-int.linecorp.com",
      "available_models": [
        {
          "name": "claude-sonnet-4.6",
          "display_name": "Claude Sonnet 4.6 (LiteLLM)",
          "max_tokens": 200000,
          "max_output_tokens": 64000,
        },
      ],
    },
  },
  "ssh_connections": [
    {
      "host": "mlu",
      "args": [],
      "projects": [
        {
          "paths": ["/root/workspace/ads-ranker-pipeline/"],
        },
      ],
    },
    {
      "host": "tommy-server",
      "args": [],
      "projects": [
        {
          "paths": ["/root/workspace/ranker-v2/"],
        },
      ],
    },
  ],
  "vim_mode": true,
  "ui_font_size": 15.0,
  "buffer_font_size": 17.0,
  "buffer_line_height": {
    "custom": 1.0
  },
  "terminal": {
    "font_size": 16.0,
    "font_family": "UDEV Gothic NFLG",
  },
  "theme": {
    "mode": "light",
    "light": "One Light",
    "dark": "Nightfox - opaque",
  },
  "relative_line_numbers": "enabled",
  "autosave": { "after_delay": { "milliseconds": 1000 } },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "project_panel": {
    "dock": "right",
    "entry_spacing": "standard",
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "!ty", "!pylsp"],
    },
  },
  "feature_flags": {
    "tabular-data-preview": "on",
    "notebooks": "on",
  },
}
